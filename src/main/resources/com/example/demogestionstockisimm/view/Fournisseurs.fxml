<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demogestionstockisimm.controller.FournisseurController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #f4f6f9;">
    <top>
        <HBox style="-fx-background-color: #2E75B6; -fx-padding: 15;" alignment="CENTER_LEFT" spacing="20">
            <Button text="← Retour" onAction="#retourMenu"
                    style="-fx-background-color: white; -fx-text-fill: #2E75B6; -fx-font-weight: bold; -fx-background-radius: 5;"/>
            <Label text="Gestion des Fournisseurs"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="tfRecherche" promptText="Rechercher par nom..."
                           prefWidth="300"/>
                <Button text="Rechercher" onAction="#rechercher"
                        style="-fx-background-color: #2E75B6; -fx-text-fill: white; -fx-background-radius: 5;"/>
                <Button text="Afficher tout" onAction="#afficherTout"
                        style="-fx-background-color: #888; -fx-text-fill: white; -fx-background-radius: 5;"/>
            </HBox>
            <TableView fx:id="tableFournisseurs" prefHeight="300">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="150"/>
                    <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120"/>
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="180"/>
                    <TableColumn fx:id="colAdresse" text="Adresse" prefWidth="200"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>
            <TitledPane text="Formulaire Fournisseur" expanded="true">
                <GridPane hgap="10" vgap="10" style="-fx-padding: 15;">
                    <Label text="Nom :" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfNom" prefWidth="250"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Téléphone :" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="tfTelephone" prefWidth="250"
                               GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Email :" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="tfEmail" prefWidth="250"
                               GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Adresse :" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="tfAdresse" prefWidth="250"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="4">
                        <Button text="Ajouter" onAction="#ajouter"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 5;"/>
                        <Button text="Modifier" onAction="#modifier"
                                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-background-radius: 5;"/>
                        <Button text="Supprimer" onAction="#supprimer"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5;"/>
                        <Button text="Vider" onAction="#viderFormulaire"
                                style="-fx-background-color: #888; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    </HBox>
                </GridPane>
            </TitledPane>
        </VBox>
    </center>
</BorderPane>