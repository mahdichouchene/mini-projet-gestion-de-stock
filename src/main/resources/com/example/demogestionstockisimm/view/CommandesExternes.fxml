<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demogestionstockisimm.controller.CommandeExterneController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #f4f6f9;">
    <top>
        <HBox style="-fx-background-color: #2E75B6; -fx-padding: 15;" alignment="CENTER_LEFT" spacing="20">
            <Button text="← Retour" onAction="#retourMenu"
                    style="-fx-background-color: white; -fx-text-fill: #2E75B6; -fx-font-weight: bold; -fx-background-radius: 5;"/>
            <Label text="Gestion des Commandes Externes"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="tfRecherche" promptText="Rechercher par fournisseur..."
                           prefWidth="300"/>
                <Button text="Rechercher" onAction="#rechercher"
                        style="-fx-background-color: #2E75B6; -fx-text-fill: white; -fx-background-radius: 5;"/>
                <Button text="Afficher tout" onAction="#afficherTout"
                        style="-fx-background-color: #888; -fx-text-fill: white; -fx-background-radius: 5;"/>
            </HBox>

            <TableView fx:id="tableCommandes" prefHeight="200">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="120"/>
                    <TableColumn fx:id="colFournisseur" text="Fournisseur" prefWidth="150"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <TitledPane text="Créer une commande" expanded="true">
                <GridPane hgap="10" vgap="10" style="-fx-padding: 15;">
                    <Label text="Date :" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <DatePicker fx:id="dpDate" prefWidth="200"
                                GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <Label text="Fournisseur :" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <ComboBox fx:id="cbFournisseur" prefWidth="200"
                              GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                    <Label text="Article :" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="cbArticle" prefWidth="200"
                              GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <Label text="Quantité :" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="tfQuantite" prefWidth="200" promptText="Ex: 10"
                               GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                    <Label text="Local de stockage :" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <ComboBox fx:id="cbLocal" prefWidth="200"
                              GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="5">
                        <Button text="Créer commande" onAction="#creer"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 5;"/>
                        <Button text="Ajouter ligne" onAction="#ajouterLigne"
                                style="-fx-background-color: #2E75B6; -fx-text-fill: white; -fx-background-radius: 5;"/>
                        <Button text="Valider" onAction="#valider"
                                style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-background-radius: 5;"/>
                        <Button text="Annuler" onAction="#annuler"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    </HBox>
                </GridPane>
            </TitledPane>

            <Label text="Traçabilité des actions :"
                   style="-fx-font-weight: bold; -fx-text-fill: #2E75B6;"/>
            <TextArea fx:id="taTrace" prefHeight="80" editable="false"
                      style="-fx-font-family: monospace; -fx-font-size: 12px;"/>

        </VBox>
    </center>
</BorderPane>