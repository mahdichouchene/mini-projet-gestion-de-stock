<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demogestionstockisimm.controller.GestionUtilisateursController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #f4f6f9;">
    <top>
        <HBox style="-fx-background-color: #2E75B6; -fx-padding: 15;" alignment="CENTER_LEFT" spacing="20">
            <Button text="← Retour" onAction="#retourMenu"
                    style="-fx-background-color: white; -fx-text-fill: #2E75B6; -fx-font-weight: bold; -fx-background-radius: 5;"/>
            <Label text="Gestion des Utilisateurs"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="10" style="-fx-padding: 15;">

            <HBox spacing="10" alignment="CENTER_LEFT">
                <CheckBox fx:id="chkVoirMdp" text="Voir les mots de passe"
                          onAction="#toggleMotsDePasse"
                          style="-fx-font-weight: bold;"/>
            </HBox>

            <TableView fx:id="tableUtilisateurs" prefHeight="320">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="50"/>
                    <TableColumn fx:id="colLogin" text="Login" prefWidth="180"/>
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="180"/>
                    <TableColumn fx:id="colMotDePasse" text="Mot de passe" prefWidth="180"/>
                    <TableColumn fx:id="colRole" text="Role" prefWidth="130"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <TitledPane text="Ajouter un utilisateur" expanded="true">
                <GridPane hgap="10" vgap="10" style="-fx-padding: 15;">

                    <Label text="Login (= Nom) :" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="tfLogin" promptText="Minimum 3 caracteres"
                               prefWidth="250"
                               GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Mot de passe :" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <PasswordField fx:id="pfMotDePasse" prefWidth="250"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label fx:id="lblInfo" text=""
                           GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <HBox spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="3">
                        <Button text="Ajouter" onAction="#ajouter"
                                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 5;"/>
                        <Button text="Supprimer selectionne" onAction="#supprimer"
                                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 5;"/>
                        <Button text="Vider" onAction="#vider"
                                style="-fx-background-color: #888; -fx-text-fill: white; -fx-background-radius: 5;"/>
                    </HBox>

                </GridPane>
            </TitledPane>

        </VBox>
    </center>
</BorderPane>
