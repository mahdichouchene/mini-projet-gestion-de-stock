<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.demogestionstockisimm.controller.MainController"
            prefWidth="900" prefHeight="650"
            style="-fx-background-color: #f4f6f9;">

    <top>
        <VBox style="-fx-background-color: #2E75B6; -fx-padding: 15;">
            <HBox alignment="CENTER_LEFT" spacing="20">
                <VBox HBox.hgrow="ALWAYS">
                    <Label text="Gestion de Stock - ISIMM"
                           style="-fx-text-fill: white; -fx-font-size: 22px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblBienvenue" text=""
                           style="-fx-text-fill: #cce0f5; -fx-font-size: 13px;"/>
                    <Label fx:id="lblRole" text=""
                           style="-fx-text-fill: #cce0f5; -fx-font-size: 12px;"/>
                </VBox>
                <Button text="Se deconnecter" onAction="#seDeconnecter"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-padding: 30;">
            <Label text="Choisir un module"
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2E75B6;"/>

            <FlowPane hgap="20" vgap="20" alignment="CENTER">

                <Button fx:id="btnArticles" text="Articles"
                        prefWidth="180" prefHeight="80"
                        onAction="#ouvrirArticles"
                        style="-fx-background-color: #2E75B6; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="btnLocaux" text="Locaux"
                        prefWidth="180" prefHeight="80"
                        onAction="#ouvrirLocaux"
                        style="-fx-background-color: #2E75B6; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="btnFournisseurs" text="Fournisseurs"
                        prefWidth="180" prefHeight="80"
                        onAction="#ouvrirFournisseurs"
                        style="-fx-background-color: #2E75B6; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="btnServices" text="Services"
                        prefWidth="180" prefHeight="80"
                        onAction="#ouvrirServices"
                        style="-fx-background-color: #1a5c9e; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="btnCommandesExternes" text="Commandes Externes"
                        prefWidth="180" prefHeight="80"
                        onAction="#ouvrirCommandesExternes"
                        style="-fx-background-color: #1a5c9e; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="btnCommandesInternes" text="Commandes Internes"
                        prefWidth="180" prefHeight="80"
                        onAction="#ouvrirCommandesInternes"
                        style="-fx-background-color: #1a5c9e; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="btnInventaire" text="Inventaire"
                        prefWidth="180" prefHeight="80"
                        onAction="#ouvrirInventaire"
                        style="-fx-background-color: #17a589; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="btnStatistiques" text="Statistiques"
                        prefWidth="180" prefHeight="80"
                        onAction="#ouvrirStatistiques"
                        style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

                <Button fx:id="btnUtilisateurs" text="Utilisateurs"
                        prefWidth="180" prefHeight="80"
                        onAction="#ouvrirUtilisateurs"
                        style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10;"/>

            </FlowPane>
        </VBox>
    </center>

    <bottom>
        <HBox style="-fx-background-color: #2E75B6; -fx-padding: 10;" alignment="CENTER">
            <Label text="ISIMM - Monastir 2025"
                   style="-fx-text-fill: white; -fx-font-size: 12px;"/>
        </HBox>
    </bottom>

</BorderPane>
